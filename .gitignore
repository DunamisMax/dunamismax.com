# Node.js / JavaScript / TypeScript

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.pid.lock

# Dependencies
node_modules/
jspm_packages/

# Build files
dist/
build/
.tmp/
.cache/

# Optional npm cache directory
.npm/

# Next.js or similar frameworks
.next/
.out/

# SvelteKit
.svelte-kit/

# Nuxt.js
.nuxt/

# Gatsby
.cache/

# Remix
.build/

# Parcel
.cache/

# Storybook build outputs
.out-storybook/
.storybook-out/

# Production
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Testing
coverage/
.nyc_output/
jest-html-reporters-*.html

# OS generated files
.DS_Store
Thumbs.db

# VSCode settings
.vscode/

# Other Editors and IDEs
.idea/
*.iml

# Logs, Databases, and Keys (if any remain from old setup)
*.sqlite
*.sqlite3
*.db
*.db-journal

# If using PM2 or similar for process management
pm2.log

# Ignore logs and temporary files from build tools
*.tgz
*.gz
*.zip

# Mac specific
.AppleDouble
.LSOverride

# Windows thumbnail cache files
Thumbs.db

# Linux trash directory
.Trash-*

# Node REPL history
.node_repl_history

# Yarn Integrity file
.yarn-integrity

# Yarn Modern (Berry) files
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# ESLint cache
.eslintcache

# Stylelint cache
.stylelintcache

# TypeScript build cache
*.tsbuildinfo

# End of Node.js/JS ignores

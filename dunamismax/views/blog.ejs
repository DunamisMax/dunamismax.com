<!-- views/blog.ejs -->
<%- include('partials/header', { title: 'Blog', activePage: 'blog' }) %>

<section class="blog-overview">
  <h2>Welcome to the Blog</h2>
  <p>Stay updated with our latest posts and insights.</p>

  <% if (posts && posts.length > 0) { %> <% posts.forEach(function(post) { %>
  <article class="blog-post">
    <h3>
      <a href="/blog/<%= post.slug %>" class="blog-post-title"
        ><%= post.title %></a
      >
    </h3>
    <p class="blog-post-excerpt"><%= post.excerpt %></p>
    <a href="/blog/<%= post.slug %>" class="btn">Read More</a>
  </article>
  <% }) %> <% } else { %>
  <p>No blog posts available at the moment.</p>
  <% } %>
</section>

<%- include('partials/footer') %>

<!-- views/contact.ejs -->
<%- include('partials/header', { title: 'Contact Us', activePage: 'contact' })
%>

<section class="contact-section">
  <h2>Contact Us</h2>
  <form action="/contact" method="POST" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

    <!-- Name Field -->
    <div class="form-group">
      <label for="name">Name</label>
      <input
        type="text"
        id="name"
        name="name"
        class="form-control <%= errors.name ? 'input-error' : '' %>"
        value="<%= form.name ? form.name : '' %>"
        required
        minlength="2"
        maxlength="100"
        aria-describedby="nameHelp"
      />
      <% if (errors.name) { %>
      <span class="error" id="nameHelp"><%= errors.name %></span>
      <% } %>
    </div>

    <!-- Email Field -->
    <div class="form-group">
      <label for="email">Email</label>
      <input
        type="email"
        id="email"
        name="email"
        class="form-control <%= errors.email ? 'input-error' : '' %>"
        value="<%= form.email ? form.email : '' %>"
        required
        maxlength="120"
        aria-describedby="emailHelp"
      />
      <% if (errors.email) { %>
      <span class="error" id="emailHelp"><%= errors.email %></span>
      <% } %>
    </div>

    <!-- Subject Field -->
    <div class="form-group">
      <label for="subject">Subject</label>
      <input
        type="text"
        id="subject"
        name="subject"
        class="form-control <%= errors.subject ? 'input-error' : '' %>"
        value="<%= form.subject ? form.subject : '' %>"
        required
        maxlength="150"
        aria-describedby="subjectHelp"
      />
      <% if (errors.subject) { %>
      <span class="error" id="subjectHelp"><%= errors.subject %></span>
      <% } %>
    </div>

    <!-- Message Field -->
    <div class="form-group">
      <label for="message">Message</label>
      <textarea
        id="message"
        name="message"
        class="form-control <%= errors.message ? 'input-error' : '' %>"
        required
        minlength="10"
        maxlength="500"
        aria-describedby="messageHelp"
      >
<%= form.message ? form.message : '' %></textarea
      >
      <% if (errors.message) { %>
      <span class="error" id="messageHelp"><%= errors.message %></span>
      <% } %>
    </div>

    <!-- Submit Button -->
    <button type="submit" class="btn">Send Message</button>
  </form>
</section>

<%- include('partials/footer') %>
